<section class="relative pt-32 pb-12 lg:pt-48 lg:pb-20 overflow-hidden bg-gradient-to-br from-marine to-marine-clair">
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mb-20"> <!-- On augmente la marge en bas -->
      <!-- Badge Statut -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 px-4 py-1.5 rounded-full mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-succes opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-succes"></span>
        </span>
        <span class="text-white text-[11px] font-medium uppercase tracking-widest">Cabinet ouvert · Lun - Ven</span>
      </div>

      <h1 class="text-5xl md:text-7xl text-white mb-8 italic leading-tight">
        Votre centre d'imagerie <br class="hidden md:block" /> médicale à Saint-Lô
      </h1>

      <p class="text-lg md:text-xl text-white/80 font-sans max-w-2xl leading-relaxed">
        Radiographie, échographie, mammographie — une expertise médicale de pointe alliée à un accompagnement humain.
      </p>
    </div>

    <!-- BARRE D'ACCÈS RAPIDE (Le secret du design pro) -->
    <div class="reveal grid grid-cols-1 md:grid-cols-3 bg-white rounded-3xl shadow-2xl overflow-hidden border border-separateur">
      
      <!-- BLOC 1 : RENDEZ-VOUS -->
      <div class="p-8 border-b md:border-b-0 md:border-r border-separateur flex flex-col justify-between">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-licorne"></span>
          <span class="text-[10px] font-bold uppercase tracking-widest text-brume">Rendez-vous</span>
        </div>
        
        <div class="space-y-3">
          <!-- Lien Doctolib -->
          <a href="https://www.doctolib.fr/centre-d-imagerie-medicale/saint-lo/centre-d-imagerie-la-licorne/booking/motives" target="_blank" class="flex items-center justify-between p-3 rounded-xl bg-ciel/40 text-marine hover:bg-marine hover:text-white transition-all group">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="font-serif italic">En ligne (Scanner)</span>
            </div>
            <span class="text-licorne group-hover:text-white transition-colors">→</span>
          </a>
    
          <!-- Lien Téléphone -->
          <a href="tel:0233571790" class="flex items-center justify-between p-3 rounded-xl bg-ciel/40 text-marine hover:bg-marine hover:text-white transition-all group">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <span class="font-serif italic">Par téléphone</span>
            </div>
            <span class="text-licorne group-hover:text-white transition-colors">→</span>
          </a>
        </div>
      </div>
    
      <!-- BLOC 2 : LOCALISATION INTERACTIF (GPS / ITINÉRAIRE) -->
<div 
x-data="{ 
  open: false, 
  copied: false, 
  copyAddress() { 
    navigator.clipboard.writeText('321 rue Alexis de Tocqueville, 50000 Saint-Lô'); 
    this.copied = true; 
    setTimeout(() => this.copied = false, 2000); 
  } 
}" 
class="p-8 border-b md:border-b-0 md:border-r border-separateur flex flex-col justify-between relative overflow-hidden bg-blanc min-h-[180px]"
>
<!-- En-tête immuable -->
<div class="flex items-center gap-2 mb-4">
  <span class="w-1.5 h-1.5 rounded-full bg-brume"></span>
  <span class="text-[10px] font-bold uppercase tracking-widest text-brume">Venir au cabinet</span>
</div>

<!-- ÉTAT 1 : Vue normale (Cliquez pour ouvrir) -->
<div 
  x-show="!open" 
  @click="open = true"
  class="cursor-pointer group flex-1 flex flex-col justify-between"
>
  <div class="text-xl text-marine font-serif italic mb-4 group-hover:text-licorne transition-colors leading-snug">
    321 rue Alexis de Tocqueville
  </div>
  <div class="flex items-center gap-2 text-xs font-medium text-licorne group-hover:translate-x-1 transition-transform">
    <svg class="w-4 h-4 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <span>Choisir un itinéraire...</span>
  </div>
</div>

<!-- ÉTAT 2 : Menu Itinéraires (Apparaît au clic sans déformer la boîte) -->
<div 
  x-show="open" 
  x-cloak 
  @click.away="open = false"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 scale-95"
  x-transition:enter-end="opacity-100 scale-100"
  class="absolute inset-x-0 bottom-0 top-[40px] bg-blanc px-6 pb-6 pt-2 flex flex-col justify-between z-20"
>
  <!-- Grille d'options de navigation spécifiques à l'itinéraire -->
  <div class="grid grid-cols-2 gap-2 text-[11px] font-medium font-sans">
    
    <!-- Google Maps (Lien itinéraire direct) -->
    <a 
      href="https://www.google.com/maps/dir/?api=1&destination=321+rue+Alexis+de+Tocqueville+50000+Saint-Lô" 
      target="_blank" 
      rel="noopener" 
      class="flex items-center justify-center p-2.5 rounded-xl bg-ciel/50 text-marine hover:bg-marine hover:text-white transition-colors text-center"
    >
      Google Maps
    </a>

    <!-- Waze (Lien navigation direct) -->
    <a 
      href="https://waze.com/ul?q=321%20rue%20Alexis%20de%20Tocqueville%2050000%20Saint-Lô&navigate=yes" 
      target="_blank" 
      rel="noopener" 
      class="flex items-center justify-center p-2.5 rounded-xl bg-ciel/50 text-marine hover:bg-marine hover:text-white transition-colors text-center"
    >
      Waze
    </a>

    <!-- Apple Plans (Lien natif iOS/macOS) -->
    <a 
      href="https://maps.apple.com/?daddr=321+rue+Alexis+de+Tocqueville+50000+Saint-Lô" 
      target="_blank" 
      rel="noopener" 
      class="flex items-center justify-center p-2.5 rounded-xl bg-ciel/50 text-marine hover:bg-marine hover:text-white transition-colors text-center"
    >
      Apple Plans
    </a>

    <!-- Copier l'adresse (Interactif avec retour visuel) -->
    <button 
      @click="copyAddress()" 
      class="p-2.5 rounded-xl text-center transition-all cursor-pointer font-bold uppercase tracking-wider text-[9px]"
      :class="copied ? 'bg-succes text-white' : 'bg-licorne/10 text-licorne hover:bg-licorne hover:text-white'"
      >
      <span x-text="copied ? '✓ Copié !' : `Copier l'adresse` "></span>
    </button>
    
  </div>

  <!-- Petit bouton de fermeture discret pour le mobile -->
  <button @click="open = false" class="text-center text-[10px] text-brume hover:text-marine uppercase tracking-widest font-bold mt-2">
    ← Retour
  </button>
</div>
</div>
    
      <!-- BLOC 3 : HORAIRES -->
      <div class="p-8 flex flex-col justify-between">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-succes"></span>
          <span class="text-[10px] font-bold uppercase tracking-widest text-brume">Horaires d'ouverture</span>
        </div>
        
        <div>
          <div class="text-xl text-marine font-serif italic mb-2">8h30 — 18h30</div>
          <div class="flex items-center gap-2 text-sm text-succes font-medium">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>Du lundi au vendredi</span>
          </div>
        </div>
      </div>
    
    </div>

  <!-- Déco de fond -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-white/5 skew-x-12 translate-x-20 -z-0"></div>
</section>