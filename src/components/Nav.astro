---
const links = [
  { name: 'Examens', href: '#examens' },
  { name: 'Parcours', href: '#parcours' },
  { name: 'Le cabinet', href: '#cabinet' },
  { name: 'Contact', href: '#contact' },
];
---

<nav class="fixed w-full z-50 bg-blanc/90 backdrop-blur-md border-b border-separateur h-20">
  <div class="container mx-auto px-6 h-full flex items-center justify-between">
    <!-- Logo SVG -->
    <a href="/" class="flex items-center gap-3 group">
      <img src="/favicon.svg" alt="Logo La Licorne" class="w-10 h-10 group-hover:rotate-12 transition-transform duration-300" />
      <div class="flex flex-col">
        <span class="font-serif text-xl text-marine leading-none">La Licorne</span>
        <span class="font-sans text-[9px] uppercase tracking-[0.2em] text-brume">Imagerie Médicale</span>
      </div>
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-medium text-ardoise hover:text-marine transition-colors">{link.name}</a>
      ))}
    </div>

    <!-- CTA -->
    <a href="https://lic1.xplore.fr/Xaportaildiffusion/" target="_blank" class="bg-marine text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-marine-sombre transition-all flex items-center gap-2 shadow-sm">
      <span>Mes résultats</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
    </a>
  </div>
</nav>