---
// src/components/Nav.astro
const links = [
  { name: 'Examens', href: 'examens' },
  { name: 'Parcours', href: '#parcours' },
  { name: 'Le cabinet', href: '#cabinet' },
  { name: 'Contact', href: '#contact' },
];
---

<nav class="fixed w-full z-50 bg-blanc/90 backdrop-blur-md border-b border-separateur" x-data="{ open: false }">
  <div class="container mx-auto px-6 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img src="/favicon.svg" alt="Logo" class="w-8 h-8" />
      <span class="font-serif text-marine text-xl italic leading-none">La Licorne</span>
    </a>

    <!-- Menu Desktop -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-medium text-ardoise hover:text-marine transition-colors">{link.name}</a>
      ))}
      <a href="https://lic1.xplore.fr/Xaportaildiffusion/" target="_blank" class="bg-marine text-white px-6 py-2.5 rounded-full text-sm font-medium shadow-sm">Mes résultats</a>
    </div>

    <!-- Bouton Mobile (Hamburger) -->
    <button @click="open = !open" class="md:hidden text-marine p-2">
      <svg x-show="!open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" /></svg>
      <svg x-show="open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>

  <!-- Menu Mobile (Overlay) -->
  <div x-show="open" 
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 -translate-y-4"
       x-transition:enter-end="opacity-100 translate-y-0"
       class="md:hidden bg-blanc border-b border-separateur px-6 pb-8 pt-2 space-y-4 absolute w-full shadow-xl">
    {links.map(link => (
      <a href={link.href} @click="open = false" class="block text-lg font-medium text-marine py-2 border-b border-separateur/50">{link.name}</a>
    ))}
    <a href="https://lic1.xplore.fr/Xaportaildiffusion/" class="block bg-marine text-white text-center py-4 rounded-xl font-bold">Consulter mes résultats</a>
  </div>
</nav>