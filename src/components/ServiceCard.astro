---
interface Props {
  titre: string;
  description: string;
  slug: string;
  icon: string;
}

const { titre, description, slug, icon } = Astro.props;
---

<a 
  href={`/examens/${slug}/`} 
  class="reveal bg-blanc p-8 rounded-3xl border border-separateur shadow-soft hover:shadow-md transition-all group flex flex-col justify-between h-full"
>
  <div>
    <!-- Icône SVG via le dossier assets -->
    <div class="w-12 h-12 bg-ciel rounded-2xl flex items-center justify-center mb-6 group-hover:bg-marine/5 transition-colors">
      <img src={`/assets/icons/${icon}`} alt="" class="w-6 h-6" aria-hidden="true" />
    </div>
    
    <!-- Titre en h3 -->
    <h3 class="text-2xl italic text-marine mb-3">{titre}</h3>
    
    <!-- Description -->
    <p class="text-sm text-brume leading-relaxed">
      {description}
    </p>
  </div>

  <!-- CTA En savoir plus -->
  <span class="text-licorne text-xs font-bold uppercase tracking-widest mt-8 flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300">
    En savoir plus <span>→</span>
  </span>
</a>