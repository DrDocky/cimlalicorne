---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PatientJourney from '../components/PatientJourney.astro';
import TeamIntro from '../components/TeamIntro.astro';
import Location from '../components/Location.astro';

import { EXAMENS } from '../data/examens';
const examensAccueil = EXAMENS; 

---

<BaseLayout 
  title="Radiologie & Échographie à Saint-Lô" 
  description="Cabinet de radiologie La Licorne : Radiographie, Échographie, Mammographie, Ostéodensitométrie et Panoramique dentaire à Saint-Lô."
>
  <Hero />
  
  <section id="examens" class="py-24 bg-ciel">
    <div class="container mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16 reveal">
        <span class="text-licorne uppercase tracking-[0.2em] text-[10px] font-bold">Expertises</span>
        <h2 class="text-4xl mt-4 italic text-marine font-serif">Nos Examens d'Imagerie</h2>
      </div>

      <!-- Utilisation du .map() avec le composant factorisé -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {examensAccueil.map((examen) => (
          <ServiceCard 
            titre={examen.titre} 
            description={examen.description} 
            slug={examen.slug} 
            icon={examen.icon} 
          />
        ))}

        <!-- Carte Spéciale "Prendre RDV" pour boucher le 6ème slot ou en bonus -->
        <div class="reveal bg-marine p-10 rounded-3xl text-white flex flex-col justify-center items-center text-center shadow-lg">
          <h3 class="text-2xl italic font-serif mb-4">Prendre rendez-vous</h3>
          <p class="text-white/60 text-sm mb-8 leading-relaxed">
            Notre secrétariat vous accueille par téléphone pour fixer vos examens.
          </p>
          <a href="tel:0233571790" class="text-2xl font-serif text-white hover:text-licorne transition-colors tracking-tight">
            02 33 57 17 90
          </a>
        </div>
      </div>
    </div>
  </section>
        
      </div>
    </div>

  <section id="parcours"><PatientJourney /></section>
  <section id="cabinet"><TeamIntro /></section>
  <Location />
</BaseLayout>