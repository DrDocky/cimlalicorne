---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Page non trouvée" 
  description="La page que vous recherchez n'est pas disponible. Centre d'Imagerie Médicale La Licorne."
>
  <section class="min-h-[85vh] flex items-center justify-center bg-ciel px-6">
    <div class="max-w-2xl w-full text-center reveal">
      
      <!-- Logo Complet -->
      <div class="mb-12 flex justify-center">
        <div class="relative group">
          <!-- Effet de halo doux derrière le logo -->
          
          <div class="absolute inset-0 bg-marine/5 rounded-full blur-3xl group-hover:bg-licorne/10 transition-colors duration-500"></div>
          
          <img 
            src="../../public/logo-complet.webp" 
            alt="CIM La Licorne" 
            class="relative w-48 md:w-20 h-auto mx-auto drop-shadow-sm grayscale-[0.2] opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
          />
        </div>
      </div>

      <div class="inline-block px-4 py-1 bg-marine/5 rounded-full text-marine text-xs font-bold uppercase tracking-widest mb-6">
        Erreur 404
      </div>

      <h1 class="text-4xl md:text-5xl italic text-marine mb-6">
        Page introuvable
      </h1>
      
      <p class="text-ardoise text-lg mb-12 leading-relaxed max-w-lg mx-auto">
        Désolé, la page que vous cherchez n'existe pas ou a été déplacée. 
        Utilisez les liens ci-dessous pour retrouver votre chemin.
      </p>

      <!-- Actions de secours -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/" 
          class="bg-marine text-white px-8 py-4 rounded-full font-medium hover:bg-marine-sombre transition-all shadow-sm flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Retour à l'accueil
        </a>
        <a 
          href="https://lic1.xplore.fr/Xaportaildiffusion/" 
          target="_blank"
          class="bg-blanc text-marine border border-separateur px-8 py-4 rounded-full font-medium hover:bg-ciel transition-all shadow-sm"
        >
          Consulter mes résultats
        </a>
      </div>

      <!-- Assistance -->
      <div class="mt-16 pt-8 border-t border-separateur">
        <p class="text-brume text-xs uppercase tracking-widest mb-4 font-bold">Secrétariat Médical</p>
        <a href="tel:0233571790" class="text-3xl font-serif text-marine hover:text-licorne transition-colors tracking-tight">
          02 33 57 17 90
        </a>
      </div>

    </div>
  </section>
</BaseLayout>