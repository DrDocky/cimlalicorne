---
import ExamenLayout from '../../layouts/ExamenLayout.astro';
import { EXAMENS } from '../../data/examens';
import { EXAMENS_CONTENT } from '../../data/examens-content';

const base = EXAMENS.find(e => e.slug === 'osteodensitometrie')!;
const content = EXAMENS_CONTENT['osteodensitometrie'];
---

<ExamenLayout base={base} content={content}>
  <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6">Résultats et Interprétation</h2>
  <p>Le résultat est exprimé par un <strong>T-score</strong>. Le médecin radiologue interprète
  ce score pour déterminer s'il existe une ostéopénie ou une ostéoporose.</p>
</ExamenLayout>