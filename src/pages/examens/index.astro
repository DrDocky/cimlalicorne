---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Location from '../../components/Location.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { EXAMENS } from '../../data/examens'; // Import des données

const pageTitle = "Tous nos examens d'Imagerie Médicale à Saint-Lô — Centre La Licorne";
const pageDesc = "Découvrez la liste complète des examens pratiqués au cabinet La Licorne : Radiographie, Échographie, Mammographie, Scanner, Panoramique dentaire.";
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <section class="pt-32 pb-20 bg-ciel">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mb-16">
        <span class="text-licorne uppercase tracking-[0.2em] text-[10px] font-bold">Plateau Technique</span>
        <h1 class="text-4xl md:text-6xl italic text-marine mt-4 leading-tight">Nos Examens d'Imagerie</h1>
        <p class="text-lg text-ardoise mt-6 leading-relaxed">
          Le Centre La Licorne à Saint-Lô regroupe l'ensemble des spécialités de l'imagerie médicale moderne. Sélectionnez un examen pour découvrir les détails du parcours patient.
        </p>
      </div>

      <!-- Le .map() remplace les 6 cartes statiques -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {EXAMENS.map((examen) => (
          <ServiceCard 
            titre={examen.titre} 
            description={examen.description} 
            slug={examen.slug} 
            icon={examen.icon} 
          />
        ))}
      </div>
    </div>
  </section>
  <Location />
</BaseLayout>