---
import ExamenLayout from '../../layouts/ExamenLayout.astro';
import { EXAMENS } from '../../data/examens';
import { EXAMENS_CONTENT } from '../../data/examens-content';

const base = EXAMENS.find(e => e.slug =='echographie')!;

const content = EXAMENS_CONTENT['echographie'];
---

<ExamenLayout base={base} content={content}>
  <!--
    Slot optionnel : insérez ici du contenu spécifique à l'échographie
    qui ne figure pas dans examens.ts (bloc note, section complémentaire, etc.)
  -->
  <div class="my-12 p-8 bg-licorne/5 rounded-3xl border-l-4 border-licorne">
    <h3 class="text-lg font-bold text-marine mb-2">Note sur les échographies de grossesse</h3>
    <p class="text-sm italic">
      Nous tenons à rappeler que <strong>les échographies obstétricales (grossesse) ne sont pas pratiquées</strong>
      au centre. Veuillez vous rapprocher d'une sage-femme ou du centre hospitalier mémorial de Saint-Lô.
    </p>
  </div>

  <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6">Nos équipements de diagnostic</h2>
  <p class="text-ardoise">
    Le centre est doté d'échographes de haute résolution utilisant des sondes multi-fréquences.
    Cette technologie garantit une pénétration optimale des ultrasons pour les organes profonds
    tout en conservant une précision millimétrique pour les zones superficielles.
  </p>
</ExamenLayout>
