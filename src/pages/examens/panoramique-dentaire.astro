---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Location from '../../components/Location.astro';

const pageTitle = "Panoramique Dentaire à Saint-Lô — Imagerie Dentaire | La Licorne";
const pageDesc = "Réalisez votre radiographie panoramique dentaire à Saint-Lô. Bilan complet pour implants, dents de sagesse et orthodontie. Résultats immédiats.";
const baseUrl = "https://cimlalicorne.fr";
const currentBuildDate = new Date().toISOString().split('T')[0];

const faqItems = [
  { q: "Quels bijoux faut-il retirer ?", a: "Il est impératif de retirer boucles d'oreilles, piercings, colliers et barrettes. Le métal crée des reflets sur l'image qui empêchent le diagnostic." },
  { q: "L'examen est-il dangereux pour les enfants ?", a: "Non, la dose d'irradiation est extrêmement faible et adaptée à la morphologie de l'enfant. C'est un examen courant en orthodontie." },
  { q: "Qu'est-ce que le Télécrâne ?", a: "Notez que notre centre ne réalise pas les télécrânes. Nous effectuons uniquement les panoramiques dentaires." }
];

const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqItems.map(item => ({ "@type": "Question", "name": item.q, "acceptedAnswer": { "@type": "Answer", "text": item.a } })) };
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `${baseUrl}/` }, { "@type": "ListItem", "position": 2, "name": "Examens", "item": `${baseUrl}/examens/` }, { "@type": "ListItem", "position": 3, "name": "Panoramique Dentaire", "item": `${baseUrl}/examens/panoramique-dentaire/` } ] };
const medicalSchema = { "@context": "https://schema.org", "@type": "MedicalWebPage", "name": pageTitle, "description": pageDesc, "lastReviewed": currentBuildDate, "about": { "@type": "MedicalProcedure", "name": "Panoramique Dentaire (Orthopantomogramme)", "procedureType": "https://schema.org/DiagnosticProcedure", "preparation": "Retirer tout objet métallique au niveau de la tête." }, "audience": { "@type": "Patient" } };
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(medicalSchema)} slot="head" />

  <section class="pt-32 pb-20 bg-blanc">
    <div class="container mx-auto px-6">
      <nav class="flex gap-2 text-[10px] uppercase tracking-widest text-brume mb-12 font-bold font-sans">
        <a href="/" class="hover:text-marine transition-colors">Accueil</a>
        <span>/</span>
        <a href="/examens/" class="hover:text-marine transition-colors">Examens</a>
        <span>/</span>
        <span class="text-marine">Panoramique Dentaire</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <div class="lg:col-span-2">
          <h1 class="text-4xl md:text-6xl italic text-marine mb-8 leading-tight">Panoramique <br/>Dentaire</h1>
          
          <div class="prose prose-slate prose-lg text-ardoise max-w-none">
            <p class="text-xl font-medium text-marine/80 mb-8 leading-relaxed">
              La radiographie panoramique dentaire permet de visualiser sur un seul cliché l'ensemble des dents, des maxillaires et des articulations temporo-mandibulaires.
            </p>

            <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6">Une Vision Globale pour votre Dentiste</h2>
            <p>
              Cet examen est un outil indispensable pour votre chirurgien-dentiste ou votre orthodontiste. Il permet de détecter des infections (abcès), des kystes, des caries non visibles à l'œil nu, ou encore de vérifier la position des dents de sagesse. C'est également l'examen préalable indispensable pour tout projet de pose d'implants dentaires ou pour le suivi d'un traitement d'orthodontie chez l'enfant et l'adulte.
            </p>

            <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6 text-marine">Préparation avant l'examen</h2>
            <ul class="space-y-3 list-none pl-0">
              <li class="bg-ciel/40 p-4 rounded-xl border border-separateur text-sm">
                <strong>Objets Métalliques :</strong> Il est impératif de retirer bijoux (boucles d'oreilles, piercings), lunettes et appareils dentaires amovibles. Le métal bloque les rayons X et rend le cliché illisible.
              </li>
              <li class="bg-ciel/40 p-4 rounded-xl border border-separateur text-sm">
                <strong>Position :</strong> L'examen s'effectue debout. Vous devez mordre une petite pièce en plastique et rester parfaitement immobile pendant environ 15 secondes.
              </li>
            </ul>

            <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6">Remboursement et Résultats</h2>
            <p>
              Le panoramique dentaire est remboursé par l'Assurance Maladie à 70% sur prescription médicale. Le Centre La Licorne pratique le tiers-payant sur la part obligatoire. Vous repartez avec votre cliché immédiatement, et le compte-rendu est transmis à votre praticien ou disponible sur notre portail en ligne.
            </p>
          </div>

          <div class="mt-20" x-data="{ active: null }">
            <h2 class="text-3xl italic text-marine mb-8 font-serif">Questions fréquentes</h2>
            <div class="space-y-4">
              {faqItems.map((item, i) => (
                <div class="border border-separateur rounded-2xl overflow-hidden bg-ciel/30">
                  <button @click={`active === ${i} ? active = null : active = ${i}`} class="w-full p-6 text-left flex justify-between items-center group focus:outline-none">
                    <span class="font-bold text-marine group-hover:text-licorne transition-colors">{item.q}</span>
                    <span class="text-2xl text-licorne font-serif leading-none" x-text={`active === ${i} ? '−' : '+'`}></span>
                  </button>
                  <div x-show={`active === ${i}`} x-collapse x-cloak class="px-6 pb-6 text-sm text-ardoise border-t border-separateur/50 pt-4">
                    {item.a}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <aside class="lg:col-span-1">
          <div class="sticky top-32 space-y-8">
            <div class="bg-marine p-8 rounded-3xl text-white shadow-xl">
              <h3 class="text-xl font-serif italic mb-4">Prendre rendez-vous</h3>
              <a href="tel:0233571790" class="flex items-center justify-center gap-3 bg-white text-marine py-4 rounded-full font-bold hover:bg-licorne transition-all text-lg">
                02 33 57 17 90
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
  <Location />
</BaseLayout>
<style>[x-cloak] { display: none !important; }</style>