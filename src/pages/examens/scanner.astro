---
import ExamenLayout from '../../layouts/ExamenLayout.astro';
import { EXAMENS } from '../../data/examens';
import { EXAMENS_CONTENT } from '../../data/examens-content';

const base = EXAMENS.find(e => e.slug === 'scanner')!;
const content = EXAMENS_CONTENT['scanner'];
---

<ExamenLayout base={base} content={content}>
  <h2 class="text-2xl font-serif italic text-marine mt-12 mb-6">Remise des comptes-rendus</h2>
  <p>Le radiologue analyse les centaines de coupes générées par l'appareil.
  Le compte-rendu final est disponible sous 24h à 48h sur notre espace patient sécurisé Xplore.</p>
</ExamenLayout>